#include "stm32f103xb.h"

#define SYSTEM_CLOCK 8000000
#define PERIOD 1000
#define MAX_PWM (PERIOD - 1)
#define MIN_PWM 0
#define BASE_SPEED 300 // Base speed for the motors
#define TURN_BIAS 100  // Additional speed for turning
#define OBSTACLE_THRESHOLD 20 // Stop or avoid obstacles closer than 20 cm
#define KP 2
#define KI 0
#define KD 0

// Global variables
volatile int motor_left_pwm = 0;
volatile int motor_right_pwm = 0;
volatile int setpoint_distance = 30; // Desired distance from obstacles
volatile int distance_error = 0;
volatile int last_error = 0;
volatile int integral = 0;

// Methods we used
void GPIO_Init(void);
void Timer_Init(void);           // TIM3 for PWM
void Ultrasonic_Init(void);      // TIM2 for echo timing
void IR_Sensor_Init(void);       // Initialize IR sensors
int Ultrasonic_GetDistance(void);
int Read_IR_Sensors(void);       // Read IR sensor values
void Motor_SetSpeed(int, int);   // Set motor speeds
void Obstacle_Avoidance(void);   // Obstacle avoidance logic
void Path_Following(void);       // Path-following logic
void HBridge_Enable(void);

int main(void)
{
    GPIO_Init();
    Timer_Init();
    Ultrasonic_Init();
    IR_Sensor_Init();
    HBridge_Enable();

    // Set motor direction forward:
    GPIOA->BSRR = GPIO_BSRR_BS0 | GPIO_BSRR_BS2;  // Set PA0 & PA2 HIGH
    GPIOA->BRR  = GPIO_BSRR_BS1 | GPIO_BSRR_BS3;  // Set PA1 & PA3 LOW

    while (1)
    {
        // Check for obstacles first
        int distance = Ultrasonic_GetDistance();

        if (distance != -1 && distance < OBSTACLE_THRESHOLD)
        {
            // If an obstacle is detected, perform obstacle avoidance
            Obstacle_Avoidance();
        }
        else
        {
            // If no obstacle is detected, perform path following
            Path_Following();
        }
    }
}

// ---------------- GPIO Setup ----------------
void GPIO_Init(void)
{
    RCC->APB2ENR |= RCC_APB2ENR_IOPAEN | RCC_APB2ENR_IOPBEN;

    // PA6/PA7 → PWM outputs
    GPIOA->CRL &= ~(GPIO_CRL_MODE6 | GPIO_CRL_CNF6 | GPIO_CRL_MODE7 | GPIO_CRL_CNF7);
    GPIOA->CRL |= (0xB << (6 * 4)) | (0xB << (7 * 4)); // Alternate Function Push-Pull, 50 MHz

    // Motor Direction Pins (PA0, PA1, PA2, PA3)
    GPIOA->CRL &= ~(GPIO_CRL_MODE0 | GPIO_CRL_CNF0 | GPIO_CRL_MODE1 | GPIO_CRL_CNF1 |
                    GPIO_CRL_MODE2 | GPIO_CRL_CNF2 | GPIO_CRL_MODE3 | GPIO_CRL_CNF3);
    GPIOA->CRL |= (0x2 << (0 * 4)) | (0x2 << (1 * 4)) | (0x2 << (2 * 4)) | (0x2 << (3 * 4));

    // PB10 = Ultrasonic Trigger → Output
    GPIOB->CRH &= ~(GPIO_CRH_MODE10 | GPIO_CRH_CNF10);
    GPIOB->CRH |= (0x2 << (10 - 8) * 4); // Output Push-Pull, 50 MHz

    // PB11 = Ultrasonic Echo → Input
    GPIOB->CRH &= ~(GPIO_CRH_MODE11 | GPIO_CRH_CNF11);
    GPIOB->CRH |= (0x4 << (11 - 8) * 4); // Input Floating

    // IR Sensors Input Pins (PB0, PB1)
    GPIOB->CRL &= ~(GPIO_CRL_MODE0 | GPIO_CRL_CNF0 | GPIO_CRL_MODE1 | GPIO_CRL_CNF1);
    GPIOB->CRL |= (0x4 << (0 * 4)) | (0x4 << (1 * 4)); // Input Floating

    // PB12 = H-Bridge Enable
    GPIOB->CRH &= ~(GPIO_CRH_MODE12 | GPIO_CRH_CNF12);
    GPIOB->CRH |= (0x2 << (12 - 8) * 4); // Output Push-Pull, 50 MHz
}

// ---------------- Timer3 PWM ----------------
void Timer_Init(void)
{
    RCC->APB1ENR |= RCC_APB1ENR_TIM3EN;

    TIM3->CR1 = 0;
    TIM3->PSC = 8 - 1;            // Timer clock = 1 MHz
    TIM3->ARR = PERIOD - 1;       // Auto-reload value
    TIM3->CCR1 = 0;
    TIM3->CCR2 = 0;

    TIM3->CCMR1 = (6 << 4) | (1 << 3) |   // CH1 PWM mode 1 + preload
                  (6 << 12) | (1 << 11);  // CH2 PWM mode 1 + preload

    TIM3->CCER = TIM_CCER_CC1E | TIM_CCER_CC2E;
    TIM3->CR1 |= TIM_CR1_CEN;
}

// ---------------- Timer2 for Ultrasonic ----------------
void Ultrasonic_Init(void)
{
    RCC->APB1ENR |= RCC_APB1ENR_TIM2EN;

    TIM2->PSC = 8 - 1;    // Timer clock = 1 MHz
    TIM2->ARR = 0xFFFF;   // Max range
    TIM2->CR1 |= TIM_CR1_CEN;
}

// ---------------- IR Sensor Initialization ----------------
void IR_Sensor_Init(void)
{
    // Assume IR sensors are connected to PB0 and PB1 (left and right)
    // GPIO has already been configured as input in GPIO_Init()
}

// ---------------- Read IR Sensors ----------------
int Read_IR_Sensors(void)
{
    int left = GPIOB->IDR & GPIO_IDR_IDR0;   // PB0 → Left sensor
    int right = GPIOB->IDR & GPIO_IDR_IDR1;  // PB1 → Right sensor

    // Return a bitmask representing sensor states
    return (left ? 0b10 : 0) | (right ? 0b01 : 0);
}

// ---------------- Set Motor PWM ----------------
void Motor_SetSpeed(int left_speed, int right_speed)
{
    if (left_speed > MAX_PWM) left_speed = MAX_PWM;
    if (left_speed < MIN_PWM) left_speed = MIN_PWM;
    if (right_speed > MAX_PWM) right_speed = MAX_PWM;
    if (right_speed < MIN_PWM) right_speed = MIN_PWM;

    TIM3->CCR1 = left_speed; // Left motor
    TIM3->CCR2 = right_speed; // Right motor
}

// ---------------- Ultrasonic Distance ----------------
int Ultrasonic_GetDistance(void)
{
    GPIOB->BSRR = GPIO_BSRR_BS10; // Trigger HIGH
    for (volatile int i = 0; i < 100; i++); // Short delay (~10 µs)
    GPIOB->BSRR = GPIO_BSRR_BR10; // Trigger LOW

    // Wait for echo HIGH
    int timeout = 30000;
    while (!(GPIOB->IDR & GPIO_IDR_IDR11) && timeout--);
    if (timeout <= 0) return -1; // Timeout occurred

    uint32_t start_time = TIM2->CNT;

    // Wait for echo LOW
    timeout = 30000;
    while ((GPIOB->IDR & GPIO_IDR_IDR11) && timeout--);
    if (timeout <= 0) return -1; // Timeout occurred

    uint32_t end_time = TIM2->CNT;

    // Calculate distance: time (µs) * speed of sound (cm/µs) / 2
    return ((end_time - start_time) * 0.0343f) / 2;
}

// ---------------- Obstacle Avoidance ----------------
void Obstacle_Avoidance(void)
{
    int distance = Ultrasonic_GetDistance();
    if (distance == -1) {
        Motor_SetSpeed(MIN_PWM, MIN_PWM); // Stop motors on timeout
        return;
    }

    distance_error = setpoint_distance - distance;
    integral += distance_error;
    int derivative = distance_error - last_error;
    last_error = distance_error;

    // PID adjustment
    int adjustment = -(KP * distance_error + KI * integral + KD * derivative);

    // Calculate motor speed
    int base_speed = MAX_PWM / 2;
    int adjusted_speed = base_speed + adjustment;

    // Clamp the adjusted speed to the valid range
    if (adjusted_speed > MAX_PWM) adjusted_speed = MAX_PWM;
    if (adjusted_speed < MIN_PWM) adjusted_speed = MIN_PWM;

    // Stop if obstacle is too close
    if (distance < OBSTACLE_THRESHOLD)
    {
        motor_left_pwm = MIN_PWM;
        motor_right_pwm = MIN_PWM;
        integral = 0; // Reset integral to avoid windup
    }
    else
    {
        motor_left_pwm = adjusted_speed;
        motor_right_pwm = adjusted_speed;
    }

    Motor_SetSpeed(motor_left_pwm, motor_right_pwm);
}

// ---------------- Path Following ----------------
void Path_Following(void)
{
    int sensor_state = Read_IR_Sensors();

    // Determine motor speeds based on sensor readings
    switch (sensor_state)
    {
        case 0b00: // No sensors ON → Stop (lost path)
            Motor_SetSpeed(MIN_PWM, MIN_PWM);
            break;

        case 0b10: // Left sensor ON → Turn left
            Motor_SetSpeed(BASE_SPEED - TURN_BIAS, BASE_SPEED + TURN_BIAS);
            break;

        case 0b01: // Right sensor ON → Turn right
            Motor_SetSpeed(BASE_SPEED + TURN_BIAS, BASE_SPEED - TURN_BIAS);
            break;

        case 0b11: // Both sensors ON → Move forward
            Motor_SetSpeed(BASE_SPEED, BASE_SPEED);
            break;
    }
}

// ---------------- H-Bridge Enable ----------------
void HBridge_Enable(void)
{
    GPIOB->BSRR = GPIO_BSRR_BS12;
}
